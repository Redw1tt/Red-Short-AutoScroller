{
  "manifest_version": 3,
  "name": "REDW1TT SCROLLER",
  "version": "1.2.2",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "shuriken.png"
  },
  "icons": {
    "128": "shuriken.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/shorts/*",
        "https://www.instagram.com/reels/*",
        "https://www.instagram.com/reels/videos/*"
      ],
      "js": ["content.js"]
    }
  ]
}